# 无限循环 Neverend 配置
# 复制此文件为 .env 并修改

# ===== 必填 =====
# 你的域名（需要已解析到本机公网IP）
# 内网使用填 localhost 即可
DOMAIN=localhost

# 公网端口（默认 80，如果 80/443 被占用，改用 18080 等非标准端口）
NEVEREND_PORT=80

# CouchDB 管理员账号密码（自定义，记住它）
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme

# ===== 可选 =====
# 数据库名称（默认 obsidian-livesync）
COUCHDB_DBNAME=obsidian-livesync

# Obsidian 端到端加密口令（留空则自动生成）
E2EE_PASSPHRASE=

# LiveSync 用户名密码（用于 Setup URI）
NEVEREND_USER=user
NEVEREND_PASSWORD=password
